# Environment Variables Configuration
# Copy this file to .env and modify the values
# 环境变量配置 — 复制为 .env 后修改

# JWT signing key (REQUIRED - use a strong random string)
# JWT 签名密钥（必须设置，请使用强随机字符串）
JWT_SECRET=your-random-secret-key-here

# Initial admin credentials (password auto-generated if empty)
# 初始管理员（密码留空则自动生成）
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=

# Email retention in days (0 = no cleanup, starred exempt)
# 邮件保留天数（0 = 不清理，星标邮件不受影响）
MAIL_RETENTION_DAYS=7
